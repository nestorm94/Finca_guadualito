@model ListaPaginadaViewModel<TipoAnimal>
@{ ViewData["Title"] = "Tipos de animal"; ViewData["ControllerName"] = "TiposAnimales"; }
<h2 class="page-title">Tipos de animal</h2>
<p><a asp-action="Create" class="btn">Nuevo</a></p>
<div class="table-wrap"><table><thead><tr><th>ID</th><th>Nombre</th><th>Acciones</th></tr></thead><tbody>
@foreach (var item in Model.Items) {
<tr><td>@item.IdTipoAnimal</td><td>@item.Nombre</td><td class="actions">
<a asp-action="Edit" asp-route-id="@item.IdTipoAnimal">Editar</a>
<a asp-action="Delete" asp-route-id="@item.IdTipoAnimal">Eliminar</a></td></tr> }
</tbody></table></div>
<partial name="_Paginacion" model="Model" />
