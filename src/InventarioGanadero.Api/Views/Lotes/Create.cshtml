@model Lote
@{ ViewData["Title"] = "Nuevo - Lotes"; }
<h2 class="page-title">Nuevo</h2>
<form asp-action="Create" method="post" class="form-card">
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="form-group"><label asp-for="Nombre"></label><input asp-for="Nombre" /><span asp-validation-for="Nombre"></span></div>
<div class="form-group"><label asp-for="Descripcion"></label><textarea asp-for="Descripcion" rows="2"></textarea></div><div class="form-group"><label asp-for="Activo"></label><input asp-for="Activo" type="checkbox" /></div>
<div class="form-actions"><button type="submit">Guardar</button><a asp-action="Index" class="btn btn-secondary">Cancelar</a></div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
