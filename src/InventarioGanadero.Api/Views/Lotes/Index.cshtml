@model ListaPaginadaViewModel<Lote>
@{ ViewData["Title"] = "Lotes"; ViewData["ControllerName"] = "Lotes"; }
<h2 class="page-title">Lotes</h2>
<p><a asp-action="Create" class="btn">Nuevo</a></p>
<div class="table-wrap"><table><thead><tr><th>ID</th><th>Nombre</th><th>Acciones</th></tr></thead><tbody>
@foreach (var item in Model.Items) {
<tr><td>@item.IdLote</td><td>@item.Nombre</td><td class="actions">
<a asp-action="Edit" asp-route-id="@item.IdLote">Editar</a>
<a asp-action="Delete" asp-route-id="@item.IdLote">Eliminar</a></td></tr> }
</tbody></table></div>
<partial name="_Paginacion" model="Model" />
