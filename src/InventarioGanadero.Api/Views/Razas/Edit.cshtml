@model Raza
@{ ViewData["Title"] = "Editar raza"; }

<h2 class="page-title">Editar raza</h2>
<form asp-action="Edit" method="post" class="form-card">
    <input type="hidden" asp-for="IdRaza" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="Nombre"></label>
        <input asp-for="Nombre" />
        <span asp-validation-for="Nombre" class="field-validation-error"></span>
    </div>
    <div class="form-actions">
        <button type="submit">Guardar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
