@model ListaPaginadaViewModel<Raza>
@{ ViewData["Title"] = "Razas"; ViewData["ControllerName"] = "Razas"; }

<h2 class="page-title">Razas</h2>
<p><a asp-action="Create" class="btn">Nueva raza</a></p>

<div class="table-wrap">
    <table>
        <thead><tr><th>ID</th><th>Nombre</th><th>Acciones</th></tr></thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.IdRaza</td>
                    <td>@item.Nombre</td>
                    <td class="actions">
                        <a asp-action="Edit" asp-route-id="@item.IdRaza">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.IdRaza">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<partial name="_Paginacion" model="Model" />
