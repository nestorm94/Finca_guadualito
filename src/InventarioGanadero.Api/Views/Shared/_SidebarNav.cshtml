@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    bool Active(string name) => string.Equals(ctrl, name, StringComparison.OrdinalIgnoreCase);
    bool InGroup(params string[] controllers) => controllers.Any(Active);
    var isAdmin = User.IsInRole("ADMINISTRADOR");
    var isOperador = User.IsInRole("OPERADOR") || isAdmin;
}

<aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
        <a asp-controller="Home" asp-action="Index" class="brand">Registro Ganadero</a>
        <p class="subtitle">DBRegistroGanadero</p>
    </div>
    <nav class="sidebar-nav" aria-label="Menú principal">
        <a asp-controller="Dashboard" asp-action="Index" class="nav-item @(Active("Dashboard") ? "active" : "")">
            <span class="nav-icon">▦</span> Dashboard
        </a>
        <a asp-controller="Animales" asp-action="Index" class="nav-item @(Active("Animales") && action != "Buscar" ? "active" : "")">
            <span class="nav-icon">🐄</span> Animales
        </a>
        <a asp-controller="Animales" asp-action="Buscar" class="nav-item @(Active("Animales") && action == "Buscar" || action == "Detalle" ? "active" : "")">
            <span class="nav-icon">📋</span> Hoja de vida
        </a>
        <a asp-controller="Vacunaciones" asp-action="Index" class="nav-item @(Active("Vacunaciones") ? "active" : "")">
            <span class="nav-icon">💉</span> Vacunaciones
        </a>
        <a asp-controller="Palpaciones" asp-action="Index" class="nav-item @(Active("Palpaciones") ? "active" : "")">
            <span class="nav-icon">🔍</span> Palpaciones
        </a>
        <a asp-controller="TratamientosVeterinarios" asp-action="Index" class="nav-item @(Active("TratamientosVeterinarios") ? "active" : "")">
            <span class="nav-icon">💊</span> Tratamientos
        </a>
        <a asp-controller="TareasGanaderas" asp-action="Index" class="nav-item @(Active("TareasGanaderas") ? "active" : "")">
            <span class="nav-icon">⚡</span> Tareas masivas
        </a>

        <details class="nav-group @(InGroup("Reproduccion") ? "has-active" : "")">
            <summary>Partos y crías</summary>
            <a asp-controller="Reproduccion" asp-action="Historial" class="@(Active("Reproduccion") && action == "Historial" ? "active" : "")">Historial partos</a>
            <a asp-controller="Reproduccion" asp-action="RegistrarParto" class="@(Active("Reproduccion") && action == "RegistrarParto" ? "active" : "")">Registrar parto</a>
        </details>

        <details class="nav-group @(InGroup("Propietarios", "Pesajes", "MovimientosAnimal", "Lotes", "Razas", "Colores", "TiposAnimales", "EstadosAnimal", "Compras", "Ventas", "Muertes") ? "has-active" : "")">
            <summary>Más módulos</summary>
            <a asp-controller="Propietarios" asp-action="Index" class="@(Active("Propietarios") ? "active" : "")">Propietarios</a>
            <a asp-controller="Pesajes" asp-action="Index" class="@(Active("Pesajes") ? "active" : "")">Pesajes</a>
            <a asp-controller="MovimientosAnimal" asp-action="Index" class="@(Active("MovimientosAnimal") ? "active" : "")">Movimientos</a>
            <a asp-controller="Lotes" asp-action="Index" class="@(Active("Lotes") ? "active" : "")">Lotes</a>
            <a asp-controller="Compras" asp-action="Index" class="@(Active("Compras") ? "active" : "")">Compras</a>
            <a asp-controller="Ventas" asp-action="Index" class="@(Active("Ventas") ? "active" : "")">Ventas</a>
            <a asp-controller="Muertes" asp-action="Index" class="@(Active("Muertes") ? "active" : "")">Muertes</a>
        </details>

        <details class="nav-group" @(isAdmin ? "open" : null)>
            <summary>Sistema</summary>
            @if (isAdmin)
            {
                <a asp-controller="Usuarios" asp-action="Index" class="@(Active("Usuarios") ? "active" : "")">Usuarios</a>
                <a asp-controller="Roles" asp-action="Index" class="@(Active("Roles") ? "active" : "")">Roles</a>
            }
            <a asp-controller="AuditoriaCambios" asp-action="Index" class="@(Active("AuditoriaCambios") ? "active" : "")">Auditoría</a>
        </details>
    </nav>
</aside>
