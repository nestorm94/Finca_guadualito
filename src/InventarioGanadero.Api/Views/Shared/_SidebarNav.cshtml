@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    bool Active(string name) => string.Equals(ctrl, name, StringComparison.OrdinalIgnoreCase);
    var isAdmin = User.IsInRole("ADMINISTRADOR");
}

<aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
        <a asp-controller="Home" asp-action="Index" class="brand">Registro Ganadero</a>
        <p class="subtitle">DBRegistroGanadero</p>
    </div>
    <nav class="sidebar-nav" aria-label="Menú principal">
        <a asp-controller="Home" asp-action="Index" class="nav-item @(Active("Home") ? "active" : "")">
            <span class="nav-icon">⌂</span> Inicio
        </a>

        <details class="nav-group" open>
            <summary>Inventario</summary>
            <a asp-controller="Animales" asp-action="Index" class="@(Active("Animales") ? "active" : "")">Animales</a>
            <a asp-controller="Propietarios" asp-action="Index" class="@(Active("Propietarios") ? "active" : "")">Propietarios</a>
            <a asp-controller="Vacunaciones" asp-action="Index" class="@(Active("Vacunaciones") ? "active" : "")">Vacunaciones</a>
            <a asp-controller="Pesajes" asp-action="Index" class="@(Active("Pesajes") ? "active" : "")">Pesajes</a>
            <a asp-controller="MovimientosAnimal" asp-action="Index" class="@(Active("MovimientosAnimal") ? "active" : "")">Movimientos</a>
        </details>

        <details class="nav-group" open>
            <summary>Catálogos</summary>
            <a asp-controller="Lotes" asp-action="Index" class="@(Active("Lotes") ? "active" : "")">Lotes</a>
            <a asp-controller="Razas" asp-action="Index" class="@(Active("Razas") ? "active" : "")">Razas</a>
            <a asp-controller="Colores" asp-action="Index" class="@(Active("Colores") ? "active" : "")">Colores</a>
            <a asp-controller="TiposAnimales" asp-action="Index" class="@(Active("TiposAnimales") ? "active" : "")">Tipos animal</a>
            <a asp-controller="EstadosAnimal" asp-action="Index" class="@(Active("EstadosAnimal") ? "active" : "")">Estados</a>
        </details>

        <details class="nav-group" open>
            <summary>Operaciones</summary>
            <a asp-controller="Compras" asp-action="Index" class="@(Active("Compras") ? "active" : "")">Compras</a>
            <a asp-controller="Ventas" asp-action="Index" class="@(Active("Ventas") ? "active" : "")">Ventas</a>
            <a asp-controller="Muertes" asp-action="Index" class="@(Active("Muertes") ? "active" : "")">Muertes</a>
            <a asp-controller="Partos" asp-action="Index" class="@(Active("Partos") ? "active" : "")">Partos</a>
            <a asp-controller="TratamientosVeterinarios" asp-action="Index" class="@(Active("TratamientosVeterinarios") ? "active" : "")">Tratamientos</a>
        </details>

        <details class="nav-group" @(isAdmin ? "open" : null)>
            <summary>Sistema</summary>
            @if (isAdmin)
            {
                <a asp-controller="Usuarios" asp-action="Index" class="@(Active("Usuarios") ? "active" : "")">Usuarios</a>
                <a asp-controller="Roles" asp-action="Index" class="@(Active("Roles") ? "active" : "")">Roles</a>
            }
            <a asp-controller="AuditoriaCambios" asp-action="Index" class="@(Active("AuditoriaCambios") ? "active" : "")">Auditoría</a>
        </details>
    </nav>
</aside>
