@model Pesaje
<form asp-action="Edit" method="post" class="form-card">
<input type="hidden" asp-for="IdPesaje" />
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<partial name="_AnimalKeyField" />
<div class="form-group"><label asp-for="FechaPesaje"></label><input asp-for="FechaPesaje" type="date" /></div>
<div class="form-group"><label asp-for="PesoKg"></label><input asp-for="PesoKg" type="number" step="0.01" /><span asp-validation-for="PesoKg"></span></div><div class="form-group"><label asp-for="Observacion"></label><textarea asp-for="Observacion" rows="2"></textarea></div>
<div class="form-actions"><button type="submit">Guardar</button><a asp-action="Index" class="btn btn-secondary">Cancelar</a></div></form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
