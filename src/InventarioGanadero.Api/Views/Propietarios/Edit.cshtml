@model Propietario
@{ ViewData["Title"] = "Editar propietario"; }
<h2 class="page-title">Editar propietario</h2>
<form asp-action="Edit" method="post" class="form-card">
<input type="hidden" asp-for="IdPropietario" />
<input type="hidden" asp-for="FechaRegistro" />
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="form-group"><label asp-for="Nombre"></label><input asp-for="Nombre" /><span asp-validation-for="Nombre"></span></div>
<div class="form-group"><label asp-for="Documento"></label><input asp-for="Documento" /></div>
<div class="form-group"><label asp-for="Telefono"></label><input asp-for="Telefono" /></div>
<div class="form-group"><label asp-for="Direccion"></label><input asp-for="Direccion" /></div>
<div class="form-group"><label asp-for="Observacion"></label><textarea asp-for="Observacion" rows="2"></textarea></div>
<div class="form-group"><label asp-for="Activo"></label><input asp-for="Activo" type="checkbox" /></div>
<div class="form-actions"><button type="submit">Guardar</button><a asp-action="Index" class="btn btn-secondary">Cancelar</a></div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
