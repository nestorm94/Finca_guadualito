@model Vacunacion
@{ ViewData["Title"] = "Nueva vacunación"; }
<h2 class="page-title">Nueva vacunación</h2>
<form asp-action="Create" method="post" class="form-card">
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<partial name="_AnimalKeyField" />
<div class="form-group"><label asp-for="FechaVacunacion"></label><input asp-for="FechaVacunacion" type="date" /><span asp-validation-for="FechaVacunacion"></span></div>
<div class="form-group"><label asp-for="NombreVacuna"></label><input asp-for="NombreVacuna" /><span asp-validation-for="NombreVacuna"></span></div>
<div class="form-group"><label asp-for="Dosis"></label><input asp-for="Dosis" /></div>
<div class="form-group"><label asp-for="Responsable"></label><input asp-for="Responsable" /></div>
<div class="form-group"><label asp-for="Observacion"></label><textarea asp-for="Observacion" rows="2"></textarea></div>
<div class="form-actions"><button type="submit">Guardar</button><a asp-action="Index" class="btn btn-secondary">Cancelar</a></div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
