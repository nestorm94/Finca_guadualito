@model MovimientoAnimal
<form asp-action="Create" method="post" class="form-card">
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<partial name="_AnimalKeyField" />
<div class="form-group"><label asp-for="FechaMovimiento"></label><input asp-for="FechaMovimiento" type="date" /></div>
<div class="form-group"><label asp-for="TipoMovimiento"></label><select asp-for="TipoMovimiento" asp-items="ViewBag.TipoMovimiento"></select></div>
<div class="form-group"><label asp-for="IdLoteOrigen"></label><select asp-for="IdLoteOrigen" asp-items="ViewBag.IdLoteOrigen"><option value="">--</option></select></div>
<div class="form-group"><label asp-for="IdLoteDestino"></label><select asp-for="IdLoteDestino" asp-items="ViewBag.IdLoteDestino"><option value="">--</option></select></div>
<div class="form-group"><label asp-for="Observacion"></label><textarea asp-for="Observacion" rows="2"></textarea></div>
<div class="form-actions"><button type="submit">Guardar</button><a asp-action="Index" class="btn btn-secondary">Cancelar</a></div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
