@model Palpacion
@{ ViewData["Title"] = "Editar palpación"; }
<h2 class="page-title">Editar palpación #@Model.IdPalpacion — @Model.Numero/@Model.Anio</h2>
<form asp-action="Edit" method="post" class="form-card">
<input type="hidden" asp-for="IdPalpacion" />
<input type="hidden" asp-for="Numero" />
<input type="hidden" asp-for="Anio" />
<div asp-validation-summary="ModelOnly"></div>
<div class="form-group"><label asp-for="FechaPalpacion"></label><input asp-for="FechaPalpacion" type="date" /></div>
<div class="form-group"><label asp-for="Resultado"></label><select asp-for="Resultado" asp-items="ViewBag.Resultado"></select></div>
<div class="form-group"><label asp-for="MesesGestacion"></label><input asp-for="MesesGestacion" type="number" /></div>
<div class="form-group"><label asp-for="MedicamentoAplicado"></label><input asp-for="MedicamentoAplicado" /></div>
<div class="form-group"><label asp-for="Dosis"></label><input asp-for="Dosis" /></div>
<div class="form-group"><label asp-for="Responsable"></label><input asp-for="Responsable" /></div>
<div class="form-group"><label asp-for="Observacion"></label><textarea asp-for="Observacion" rows="2"></textarea></div>
<div class="form-actions">
<button type="submit">Guardar</button>
<a asp-controller="Animales" asp-action="Detalle" asp-route-numero="@Model.Numero" asp-route-anio="@Model.Anio" class="btn btn-secondary">Hoja de vida</a>
</div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
