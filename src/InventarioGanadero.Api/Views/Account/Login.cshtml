@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Iniciar sesión";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Registro Ganadero</title>
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body class="login-page">
    <div class="login-card">
        <div class="login-brand">
            <h1>Registro Ganadero</h1>
            <p>Inventario y vacunaciones</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="login-alert" role="alert">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <span>@error.ErrorMessage</span>
                }
            </div>
        }

        <form asp-action="Login" method="post" class="login-form">
            <input type="hidden" asp-for="ReturnUrl" />
            <div class="form-group">
                <label asp-for="Usuario"></label>
                <input asp-for="Usuario" autocomplete="username" placeholder="Usuario" autofocus />
                <span asp-validation-for="Usuario" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" autocomplete="current-password" placeholder="Contraseña" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>
            <button type="submit" class="btn-login">Ingresar</button>
        </form>
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.20.0/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
