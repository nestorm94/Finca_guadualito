@model ListaPaginadaViewModel<Venta>
@{ ViewData["Title"]="Ventas"; ViewData["ControllerName"]="Ventas"; }
<h2 class="page-title">Ventas</h2><p><a asp-action="Create" class="btn">Nuevo</a></p>
<div class="table-wrap"><table><thead><tr><th>ID</th><th>Animal</th><th>Fecha</th><th>Valor</th><th>Acciones</th></tr></thead><tbody>
@foreach(var i in Model.Items){<tr><td>@i.IdVenta</td><td>@i.Numero / @i.Anio</td><td>@i.FechaVenta.ToString("dd/MM/yyyy")</td><td>@i.ValorVenta</td>
<td class="actions"><a asp-action="Edit" asp-route-id="@i.IdVenta">Editar</a> <a asp-action="Delete" asp-route-id="@i.IdVenta">Eliminar</a></td></tr>}
</tbody></table></div><partial name="_Paginacion" model="Model" />
