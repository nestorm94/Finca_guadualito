@model ListaPaginadaViewModel<Usuario>
@{ ViewData["Title"]="Usuarios"; ViewData["ControllerName"]="Usuarios"; }
<h2 class="page-title">Usuarios</h2><p><a asp-action="Create" class="btn">Nuevo</a></p>
<div class="table-wrap"><table><thead><tr><th>ID</th><th>Nombre</th><th>Usuario</th><th>Rol</th><th>Activo</th><th></th></tr></thead><tbody>
@foreach(var i in Model.Items){<tr><td>@i.IdUsuario</td><td>@i.NombreCompleto</td><td>@i.UsuarioLogin</td><td>@i.Rol?.NombreRol</td><td>@(i.Activo?"Si":"No")</td>
<td class="actions"><a asp-action="Edit" asp-route-id="@i.IdUsuario">Editar</a> <a asp-action="Delete" asp-route-id="@i.IdUsuario">Eliminar</a></td></tr>}
</tbody></table></div><partial name="_Paginacion" model="Model" />
