@model Muerte
<form asp-action="Create" method="post" class="form-card">
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<partial name="_AnimalKeyField" />
<div class="form-group"><label asp-for="FechaMuerte"></label><input asp-for="FechaMuerte" type="date" /><span asp-validation-for="FechaMuerte"></span></div>
<div class="form-group"><label asp-for="Causa"></label><input asp-for="Causa" /></div>
<div class="form-actions"><button type="submit">Guardar</button><a asp-action="Index" class="btn btn-secondary">Cancelar</a></div></form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
