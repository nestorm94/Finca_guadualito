@model ListaPaginadaViewModel<Muerte>
@{ ViewData["Title"]="Muertes"; ViewData["ControllerName"]="Muertes"; }
<h2 class="page-title">Muertes</h2><p><a asp-action="Create" class="btn">Nuevo</a></p>
<div class="table-wrap"><table><thead><tr><th>ID</th><th>Animal</th><th>Fecha</th><th>Causa</th><th>Acciones</th></tr></thead><tbody>
@foreach(var i in Model.Items){<tr><td>@i.IdMuerte</td><td>@i.Numero / @i.Anio</td><td>@i.FechaMuerte.ToString("dd/MM/yyyy")</td><td>@i.Causa</td>
<td class="actions"><a asp-action="Edit" asp-route-id="@i.IdMuerte">Editar</a> <a asp-action="Delete" asp-route-id="@i.IdMuerte">Eliminar</a></td></tr>}
</tbody></table></div><partial name="_Paginacion" model="Model" />
