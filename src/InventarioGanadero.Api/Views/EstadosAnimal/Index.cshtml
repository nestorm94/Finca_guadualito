@model ListaPaginadaViewModel<EstadoAnimal>
@{ ViewData["Title"] = "Estados"; ViewData["ControllerName"] = "EstadosAnimal"; }
<h2 class="page-title">Estados</h2>
<p><a asp-action="Create" class="btn">Nuevo</a></p>
<div class="table-wrap"><table><thead><tr><th>ID</th><th>Nombre</th><th>Acciones</th></tr></thead><tbody>
@foreach (var item in Model.Items) {
<tr><td>@item.IdEstadoAnimal</td><td>@item.Nombre</td><td class="actions">
<a asp-action="Edit" asp-route-id="@item.IdEstadoAnimal">Editar</a>
<a asp-action="Delete" asp-route-id="@item.IdEstadoAnimal">Eliminar</a></td></tr> }
</tbody></table></div>
<partial name="_Paginacion" model="Model" />
