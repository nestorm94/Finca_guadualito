@model ListaPaginadaViewModel<Rol>
@{ ViewData["Title"] = "Roles"; ViewData["ControllerName"] = "Roles"; }
<h2 class="page-title">Roles</h2>
<p><a asp-action="Create" class="btn">Nuevo</a></p>
<div class="table-wrap"><table><thead><tr><th>ID</th><th>Nombre</th><th>Acciones</th></tr></thead><tbody>
@foreach (var item in Model.Items) {
<tr><td>@item.IdRol</td><td>@item.NombreRol</td><td class="actions">
<a asp-action="Edit" asp-route-id="@item.IdRol">Editar</a>
<a asp-action="Delete" asp-route-id="@item.IdRol">Eliminar</a></td></tr> }
</tbody></table></div>
<partial name="_Paginacion" model="Model" />
