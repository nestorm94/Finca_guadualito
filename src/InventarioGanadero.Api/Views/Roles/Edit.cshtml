@model Rol
@{ ViewData["Title"] = "Editar"; }
<h2 class="page-title">Editar</h2>
<form asp-action="Edit" method="post" class="form-card">
<input type="hidden" asp-for="IdRol" />
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="form-group"><label asp-for="NombreRol"></label><input asp-for="NombreRol" /><span asp-validation-for="NombreRol"></span></div>

<div class="form-actions"><button type="submit">Guardar</button><a asp-action="Index" class="btn btn-secondary">Cancelar</a></div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
