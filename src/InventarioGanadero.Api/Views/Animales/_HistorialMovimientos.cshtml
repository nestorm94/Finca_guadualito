@model IList<InventarioGanadero.Infrastructure.Entities.MovimientoAnimal>
@if (Model.Count == 0) { <p class="hint">Sin registros.</p> }
else
{
    <div class="table-wrap"><table>
        <thead><tr><th>Fecha</th><th>Tipo</th><th>Origen</th><th>Destino</th><th>Obs.</th></tr></thead>
        <tbody>
        @foreach (var m in Model) {
            <tr>
                <td>@m.FechaMovimiento.ToString("dd/MM/yyyy")</td>
                <td>@m.TipoMovimiento</td>
                <td>@(m.LoteOrigen?.Nombre ?? "—")</td>
                <td>@(m.LoteDestino?.Nombre ?? "—")</td>
                <td>@(m.Observacion ?? "—")</td>
            </tr>
        }
        </tbody>
    </table></div>
}
