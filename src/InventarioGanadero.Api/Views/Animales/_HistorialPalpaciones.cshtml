@model IList<InventarioGanadero.Infrastructure.Entities.Palpacion>
@if (Model.Count == 0) { <p class="hint">Sin registros.</p> }
else
{
    <div class="table-wrap"><table>
        <thead><tr><th>Fecha</th><th>Resultado</th><th>Meses gest.</th><th>Medicamento</th><th>Responsable</th><th></th></tr></thead>
        <tbody>
        @foreach (var p in Model) {
            <tr>
                <td>@p.FechaPalpacion.ToString("dd/MM/yyyy")</td>
                <td><span class="badge">@p.Resultado</span></td>
                <td>@(p.MesesGestacion?.ToString() ?? "—")</td>
                <td>@(p.MedicamentoAplicado ?? "—")</td>
                <td>@(p.Responsable ?? "—")</td>
                <td>
                    @if (User.IsInRole("ADMINISTRADOR") || User.IsInRole("OPERADOR"))
                    {
                        <a asp-controller="Palpaciones" asp-action="Edit" asp-route-id="@p.IdPalpacion">Editar</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table></div>
}
