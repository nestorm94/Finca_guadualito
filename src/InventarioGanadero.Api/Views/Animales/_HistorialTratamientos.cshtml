@model IList<InventarioGanadero.Infrastructure.Entities.TratamientoVeterinario>
@if (Model.Count == 0) { <p class="hint">Sin registros.</p> }
else
{
    <div class="table-wrap"><table>
        <thead><tr><th>Fecha</th><th>Medicamento</th><th>Dosis</th><th>Motivo</th><th>Responsable</th><th>Obs.</th></tr></thead>
        <tbody>
        @foreach (var t in Model) {
            <tr>
                <td>@t.FechaTratamiento.ToString("dd/MM/yyyy")</td>
                <td>@(t.Medicamento ?? "—")</td>
                <td>@(t.Dosis ?? "—")</td>
                <td>@(t.Enfermedad ?? "—")</td>
                <td>@(t.Responsable ?? "—")</td>
                <td>@(t.Observacion ?? "—")</td>
            </tr>
        }
        </tbody>
    </table></div>
}
