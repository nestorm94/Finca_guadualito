@model IList<InventarioGanadero.Infrastructure.Entities.Vacunacion>
@if (Model.Count == 0) { <p class="hint">Sin registros.</p> }
else
{
    <div class="table-wrap"><table>
        <thead><tr><th>Fecha</th><th>Vacuna</th><th>Dosis</th><th>Responsable</th><th>Obs.</th></tr></thead>
        <tbody>
        @foreach (var v in Model) {
            <tr>
                <td>@v.FechaVacunacion.ToString("dd/MM/yyyy")</td>
                <td>@v.NombreVacuna</td>
                <td>@(v.Dosis ?? "—")</td>
                <td>@(v.Responsable ?? "—")</td>
                <td>@(v.Observacion ?? "—")</td>
            </tr>
        }
        </tbody>
    </table></div>
}
