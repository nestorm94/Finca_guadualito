@model Animal
@{ ViewData["Title"] = "Nuevo animal"; }
<h2 class="page-title">Nuevo animal</h2>
<form asp-action="Create" method="post" class="form-card">
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<partial name="_AnimalFormFields" model="Model" />
<div class="form-actions"><button type="submit">Guardar</button><a asp-action="Index" class="btn btn-secondary">Cancelar</a></div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
