@model Compra
<form asp-action="Edit" method="post" class="form-card">
<input type="hidden" asp-for="IdCompra" />
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<partial name="_AnimalKeyField" />
<div class="form-group"><label asp-for="FechaCompra"></label><input asp-for="FechaCompra" type="date" /></div>
<div class="form-group"><label asp-for="ValorCompra"></label><input asp-for="ValorCompra" type="number" step="0.01" /></div><div class="form-group"><label asp-for="Vendedor"></label><input asp-for="Vendedor" /></div>
<div class="form-actions"><button type="submit">Guardar</button><a asp-action="Index" class="btn btn-secondary">Cancelar</a></div></form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
